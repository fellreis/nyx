{
  "compilerOptions": {
    "target": "ES2020",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "lib": [
      "ES2020"
    ],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {}
  }
}
